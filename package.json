{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "effect-oxlint",
  "version": "0.1.1",
  "description": "Effect-first library for writing oxlint custom lint rules",
  "keywords": [
    "ast",
    "effect",
    "eslint",
    "lint",
    "linter",
    "oxc",
    "oxlint",
    "plugin",
    "rules",
    "typescript"
  ],
  "homepage": "https://github.com/mpsuesser/effect-oxlint#readme",
  "bugs": {
    "url": "https://github.com/mpsuesser/effect-oxlint/issues"
  },
  "license": "MIT",
  "author": "Marc Suesser",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpsuesser/effect-oxlint.git"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bunx --bun vp build",
    "check": "bunx --bun vp check --fix",
    "test": "vitest run",
    "typecheck": "tsgo",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.57.0"
  },
  "devDependencies": {
    "@effect/tsgo": "^0.1.1",
    "@effect/vitest": "4.0.0-beta.57",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "effect": "4.0.0-beta.57",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.15",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.57"
  },
  "overrides": {
    "effect": "4.0.0-beta.57",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15"
  },
  "packageManager": "bun@1.3.12"
}
